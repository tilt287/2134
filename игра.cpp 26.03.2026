#include <iostream>
#include <cstdlib> 
#include <ctime>  
#include <limits>  

using namespace std;


int main() {
    setlocale(0, ""); 
    char name[100];
    srand(time(0));

    int setting = 1; 
    int choice;

    do {
        cout << "--- Game counter ---\n";
        cout << "1. Начать игру\n";
        cout << "2. Настройки\n";
        cout << "3. Выход\n";
        cout << "Текущая сложность: ";

        switch (setting) {
        case 1: cout << "Лёгкая (+, 1 очко)"; break;
        case 2: cout << "Средняя (-+, 2 очка)"; break; 
        case 3: cout << "Высокая (*, 3 очка)"; break; 
        case 4: cout << "Очень высокая (Микс, 5 очков)"; break;
        }
        cout << "\nВаш выбор: ";

       
        if (!(cin >> choice)) {
            cout << "Некорректный ввод. Пожалуйста, введите число.\n";
            choice = 0; 
            continue;
        }
        system("cls"); 

        switch (choice) {
        case 2: { 
            cout << "--- НАСТРОЙКИ ---\n";
            cout << "1. Лёгкая (+, 1 очко)\n";
            cout << "2. Средняя (-, +, 2 очка)\n";
            cout << "3. Высокая (*, 3 очка)\n";
            cout << "4. Очень высокая (Микс, 5 очков)\n";
            cout << "Выберите сложность (1-4): ";

            if (!(cin >> setting)) {
                cout << "Некорректный ввод. Пожалуйста, введите число.\n";
                        
                setting = 1; 
            }
            else {
                if (setting < 1 || setting > 4) {
                    cout << "Недопустимый выбор сложности. Установлена сложность по умолчанию (Лёгкая).\n";
                    setting = 1;
                }
            }
            system("cls");
            break;
        }
        case 1: { 
            cout << "\nВаше имя: ";
            cin.getline(name, 100); 

            int correct = 0;
            int score = 0;
            int lives = 5;
            int points_per_correct;
            int MAX_QUESTIONS = 10; 
            int asked_count = 0;

            
            switch (setting) {
            case 1: points_per_correct = 1; break;
            case 2: points_per_correct = 2; break;
            case 3: points_per_correct = 3; break;
            case 4: points_per_correct = 5; break;
            default: points_per_correct = 1; 
            }

            cout << "\n--- Начинаем игру! ---\n";
            cout << "Игрок: " << name << "\n";
            cout << "У вас " << lives << " жизней. Каждая ошибка отнимает 1 жизнь.\n";
            cout << "За каждый правильный ответ вы получите " << points_per_correct << " очков.\n";
            cout << "Игра закончится, если у вас закончатся жизни или вы ответите на " << MAX_QUESTIONS << " вопросов.\n\n";

            while (lives > 0 && asked_count < MAX_QUESTIONS) {
                int num1, num2, ans, user_answer;
                char operation_symbol = '?'; 
                bool operation_set = false; 

                switch (setting) {
                case 1: { 
                    num1 = rand() % 90 + 10;
                    num2 = rand() % 90 + 10;
                    operation_symbol = '+';
                    ans = num1 + num2;
                    operation_set = true;
                    break;
                }
                case 2: { 
                    num1 = rand() % 90 + 10;
                    num2 = rand() % 90 + 10;
                    if (rand() % 2 == 0) { 
                        operation_symbol = '-';
                        if (num1 < num2) { 
                            int temp = num1;
                            num1 = num2;
                            num2 = temp;
                        }
                        ans = num1 - num2;
                    }
                    else { 
                        operation_symbol = '+';
                        ans = num1 + num2;
                    }
                    operation_set = true;
                    break;
                }
                case 3: { 
                    int op_type = rand() % 2;
                    if (op_type == 0) { 
                        num1 = rand() % 900 + 100; 
                        num2 = rand() % 900 + 100; 
                        operation_symbol = '*';
                        ans = num1 * num2;
                    }
                    else { 
                        ans = rand() % 900 + 100;    
                        num2 = rand() % 900 + 100;   
                        num1 = ans * num2;           
                        operation_symbol = '/';
                    }
                    operation_set = true;
                    break;
                }
                case 4: { 
                    int op_type = rand() % 4; 
                    switch (op_type) {
                    case 0: 
                        num1 = rand() % 9000 + 1000; 
                        num2 = rand() % 9000 + 1000;
                        operation_symbol = '+';
                        ans = num1 + num2;
                        break;
                    case 1: 
                        num1 = rand() % 9000 + 1000;
                        num2 = rand() % 9000 + 1000;
                        if (num1 < num2) { 
                            int temp = num1;
                            num1 = num2;
                            num2 = temp;
                        }
                        operation_symbol = '-';
                        ans = num1 - num2;
                        break;
                    case 2: 
                        num1 = rand() % 9000 + 1000;
                        num2 = rand() % 9000 + 1000;
                        operation_symbol = '*';
                        ans = num1 * num2;
                        break;
                    case 3: 
                        ans = rand() % 9000 + 1000;
                        num2 = rand() % 9000 + 1000; 
                        num1 = ans * num2;          
                        operation_symbol = '/';
                        break;
                    }
                    operation_set = true;
                    break;
                }
                default: 
                    cout << "Ошибка в настройках сложности. Используется режим 'Лёгкая'.\n";
                    setting = 1; 
                    num1 = rand() % 90 + 10;
                    num2 = rand() % 90 + 10;
                    operation_symbol = '+';
                    ans = num1 + num2;
                    operation_set = true;
                    break;
                }

                
                if (operation_set) {
                    asked_count++;
                    cout << "Вопрос " << asked_count << "/" << MAX_QUESTIONS << " (Жизни:  " << lives << ") | ";
                    cout << num1 << " " << operation_symbol << " " << num2 << " = ";

                    
                    if (!(cin >> user_answer)) {
                        cout << "Некорректный ввод. Ответ не засчитан.\n";
                        cin.clear();
                       
                        lives--; 
                        cout << "Правильный ответ был: " << ans << "\n";
                    }
                    else {
                       
                       
                        if (user_answer == ans) {
                            cout << "Верно! +" << points_per_correct << " очков\n";
                            correct++;
                            score += points_per_correct;
                        }
                        else {
                            lives--;
                            cout << "Ошибка! Правильный ответ: " << ans << "\n";
                        }
                    }
                }
                else {
                    
                    cout << "Ошибка генерации вопроса. Пропускаем.\n";
                    lives--; 
                }
                cout << "-----------------------------------\n"; 
            } 

            
            cout << "\n==== РЕЗУЛЬТАТ ИГРЫ ====\n";
            cout << "Игрок: " << name << "\n";
            cout << "Правильных ответов: " << correct << " из " << asked_count << "\n";
            cout << "Итоговое количество очков: " << score << "\n";
            if (lives == 0) {
                cout << "У вас закончились жизни. Игра окончена.\n";
            }
            else {
                cout << "Вы ответили на все вопросы!\n";
            }
            cout << "=========================\n\n";
            break; 
        }
        case 3: { 
            cout << "Спасибо за игру! До свидания!\n";
            break; 
        }
        default: { 
            cout << "Неверный выбор. Пожалуйста, введите 1, 2 или 3.\n";
            break;
        }
        } 
    } while (choice != 3); 

    return 0;
}
